# ──────────────────────────────────────────────────────────────────────────────
# Moltbook Oversight Agent — environment variables
#
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
#
# Both usage paths pick this up automatically:
#   • docker compose   — via the env_file directive in docker-compose.yml
#   • script / uv run  — train.py loads .env via python-dotenv at startup
#                        (searches the current working directory upward)
#
# Never commit .env to version control — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Model selection ───────────────────────────────────────────────────────────
# Overrides the interactive menu. Any Unsloth model identifier works here.
# Leave blank to use the default (unsloth/Llama-3.2-3B-Instruct) or to
# get the interactive menu when stdin is a TTY.
#
# Options:
#   unsloth/Llama-3.2-1B-Instruct      fp8  — T4 14 GB (free tier, fastest)
#   unsloth/Qwen3-8B                   fp8  — L4 22 GB
#   unsloth/DeepSeek-R1-0528-Qwen3-8B  4bit — L4/A100, reasoning model
#   unsloth/Llama-3.2-3B-Instruct      16bit— T4/L4  [default]
#   unsloth/gpt-oss-20b-BF16           bf16 — A100/H100 80 GB
GRPO_MODEL=unsloth/Llama-3.2-3B-Instruct

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Required only if you use --push-to-hub.
HF_TOKEN=
HF_USERNAME=

# ── LLM Bot Mode (optional — only needed when --use-llm-bots is set) ─────────
# Each backend needs its own key. Only set the one(s) you actually use.
# Ollama runs locally and needs no API key.

# Anthropic Claude (default participant + oracle backend)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# ── Weights & Biases (optional — only needed when --report-to wandb) ─────────
WANDB_API_KEY=
WANDB_PROJECT=moltbook-oversight
WANDB_ENTITY=
